generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @unique
  slug        String   @unique
  name        String
  category    String
  price       Float
  rating      Float
  reviews     Int
  image       String
  description String
  stock       Int
  tags           String[] @default([])
  variantImages  String[] @default([])
  /** Extra images for the product page gallery carousel (lifestyle, detail shots). */
  galleryImages  String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model TagCollection {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tagId      String   @unique
  productIds String[] @default([])
  updatedAt  DateTime @updatedAt

  @@map("tag_collections")
}

model StoreSettings {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  key                       String   @unique @default("default")
  freeShippingEnabled       Boolean  @default(true)
  freeShippingThreshold     Float    @default(200)
  shippingFee               Float    @default(15)
  freeShippingRewardLabel   String   @default("free shipping")
  freeShippingProgressLabel String   @default("{{amount}} away from free shipping")
  freeShippingUnlockedLabel String   @default("You've unlocked free shipping on this order.")
  promos                    Json     @default("[]")
  updatedAt                 DateTime @updatedAt

  @@map("store_settings")
}

model Order {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String   @unique
  paystackReference String   @unique
  customerName      String
  customerEmail     String
  customerPhone     String?
  shippingAddress   String?
  items             Json
  subtotal          Float
  shipping          Float
  discount          Float
  total             Float
  currency          String
  paymentStatus     String   @default("Payment pending")
  fulfillmentStatus String   @default("Unfulfilled")
  channel           String   @default("Online store")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("orders")
}

model Customer {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId        String   @unique
  name              String
  email             String   @default("")
  phone             String   @default("")
  location          String   @default("")
  emailSubscription String   @default("Not subscribed")
  source            String   @default("manual")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("customers")
}

model SmileScan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  scanId       String   @unique
  customerName String?
  sessionId    String?
  report       Json
  brightness   Int      @default(0)
  freshness    Int      @default(0)
  confidence   Int      @default(0)
  overallScore Int      @default(0)
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("smile_scans")
}

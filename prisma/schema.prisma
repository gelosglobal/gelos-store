generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @unique
  slug        String   @unique
  name        String
  category    String
  price       Float
  rating      Float
  reviews     Int
  image       String
  description String
  stock       Int
  tags           String[] @default([])
  variantImages  String[] @default([])
  /** Named variant tiles: [{ url, label }] for flavour/style picker labels. */
  variantImageOptions Json     @default("[]")
  /** Extra images in the product page gallery carousel. */
  galleryImages  String[] @default([])
  /** Optional thumbnails under the main product image; falls back to variant images when empty. */
  carouselImages String[] @default([])
  /** When false, product is hidden from the storefront (draft). */
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model TagCollection {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  tagId      String   @unique
  productIds String[] @default([])
  updatedAt  DateTime @updatedAt

  @@map("tag_collections")
}

model StoreSettings {
  id                        String   @id @default(auto()) @map("_id") @db.ObjectId
  key                       String   @unique @default("default")
  freeShippingEnabled       Boolean  @default(true)
  freeShippingThreshold     Float    @default(200)
  shippingFee               Float    @default(15)
  freeShippingRewardLabel   String   @default("free shipping")
  freeShippingProgressLabel String   @default("{{amount}} away from free shipping")
  freeShippingUnlockedLabel String   @default("You've unlocked free shipping on this order.")
  promos                    Json     @default("[]")
  cartUpsells               Json     @default("{}")
  updatedAt                 DateTime @updatedAt

  @@map("store_settings")
}

model Order {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String   @unique
  paystackReference String   @unique
  customerName      String
  customerEmail     String
  customerPhone     String?
  shippingAddress   String?
  items             Json
  subtotal          Float
  shipping          Float
  discount          Float
  total             Float
  currency          String
  paymentStatus     String   @default("Payment pending")
  fulfillmentStatus String   @default("Unfulfilled")
  channel           String   @default("Online store")
  affiliateCode     String?
  affiliateId       String?
  commissionAmount  Float    @default(0)
  commissionStatus  String   @default("none")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("orders")
}

model Affiliate {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  affiliateId       String   @unique
  code              String   @unique
  name              String
  email             String   @default("")
  phone             String   @default("")
  commissionPercent Float    @default(10)
  enabled           Boolean  @default(true)
  totalOrders       Int      @default(0)
  totalRevenue      Float    @default(0)
  totalCommission   Float    @default(0)
  pendingCommission Float    @default(0)
  paidCommission    Float    @default(0)
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("affiliates")
}

model Customer {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId        String   @unique
  name              String
  email             String   @default("")
  phone             String   @default("")
  location          String   @default("")
  emailSubscription String   @default("Not subscribed")
  lifetimeOrders    Int      @default(0)
  lifetimeSpent     Float    @default(0)
  lifetimeCurrency  String   @default("GHS")
  source            String   @default("manual")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("customers")
}

model SmileScan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  scanId       String   @unique
  customerName String?
  sessionId    String?
  report       Json
  brightness   Int      @default(0)
  freshness    Int      @default(0)
  confidence   Int      @default(0)
  overallScore Int      @default(0)
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("smile_scans")
}

model SmileRewardClaim {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  claimId      String   @unique
  email        String   @unique
  customerName String   @default("")
  scanId       String?
  rewardType   String
  rewardTitle  String
  promoCode    String   @default("")
  productHref  String   @default("")
  redeemedAt   DateTime?
  createdAt    DateTime @default(now())

  @@map("smile_reward_claims")
}

model InboxThread {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId      String   @unique
  customerName  String
  customerEmail String
  customerPhone String   @default("")
  subject       String   @default("")
  status        String   @default("open") // open | closed
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inbox_threads")
}

model InboxMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId String   @unique
  threadId  String
  direction String   @default("in") // in | out
  body      String
  sentBy    String   @default("") // optional admin identifier
  createdAt DateTime @default(now())

  @@map("inbox_messages")
}

/** Anonymous storefront presence for live analytics (heartbeat updates lastSeenAt). */
model VisitorSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  visitorId   String   @unique
  path        String   @default("/")
  referrer    String   @default("")
  lastSeenAt  DateTime @default(now())
  firstSeenAt DateTime @default(now())

  @@map("visitor_sessions")
}

/** Gelos AI dentist booking requests from the storefront. */
model DentistAppointment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  appointmentId String   @unique
  dentistId     String
  patientName   String
  patientEmail  String
  patientPhone  String
  preferredDate String
  preferredTime String
  reason        String   @default("")
  status        String   @default("pending") // pending | confirmed | completed | cancelled
  dentistNotes  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("dentist_appointments")
}

# Prisma reads DATABASE_URL (recommended)
# Database name is required in the path (e.g. /gelos before ?)
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/gelos?retryWrites=true&w=majority

# Legacy alias — also supported if DATABASE_URL is unset
MONGODB_URI=

# UploadThing — file storage for admin product images & branding
# Create a token at https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=

# Paystack — checkout payments (secret key stays server-side only)
# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=

# Exchange rates from catalog base currency (GHS) to checkout currencies.
# Units of target currency per 1 GHS. Update with live rates as needed.
# EXCHANGE_RATES={"GHS":1,"USD":0.064,"NGN":108}

# Optional — used for Paystack callback URLs and email links in production
# Use your canonical domain, no trailing slash (https://gelosglobal.com)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Better Auth — admin CMS sign-in (/admin/login)
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Must match your live site origin (https://gelosglobal.com). No trailing slash.
# If users can visit both www and non-www, both are trusted automatically.
BETTER_AUTH_URL=https://your-domain.com
# Optional extra origins (comma-separated), e.g. Vercel preview URLs
# BETTER_AUTH_TRUSTED_ORIGINS=https://gelos-store.vercel.app
# Set to true only if your proxy exposes the public host via x-forwarded-host only
# BETTER_AUTH_TRUSTED_PROXY_HEADERS=false
# Optional comma-separated user IDs that always have admin access
BETTER_AUTH_ADMIN_USER_IDS=

# Bootstrap the first Gelos admin account (run: pnpm db:seed-admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Gelos Admin

# Meta Pixel — ad conversion tracking (https://business.facebook.com/events_manager)
NEXT_PUBLIC_META_PIXEL_ID=

# Storefront WhatsApp chat button (bottom-right). Digits only with country code.
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Optional pre-filled message when opening WhatsApp
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi Gelos! I'd like some help with my order.

# Groq — Gelos AI shopping assistant (https://console.groq.com/keys)
GROQ_API_KEY=

# Resend — order confirmation + admin alerts (domain: gelosglobal.com)
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender on your Resend domain
RESEND_FROM_EMAIL=Gelos <orders@gelosglobal.com>
# Inbox(es) that receive new-order notifications (comma-separated for multiple)
ADMIN_NOTIFICATION_EMAIL=hello@gelosglobal.com,gelosbrandinfo@gmail.com

# Mark's Dental Clinic partner portal — /dentist
DENTIST_DASHBOARD_PASSWORD=

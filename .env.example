# Prisma reads DATABASE_URL (recommended)
# Database name is required in the path (e.g. /gelos before ?)
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/gelos?retryWrites=true&w=majority

# Legacy alias — also supported if DATABASE_URL is unset
MONGODB_URI=

# UploadThing — file storage for admin product images & branding
# Create a token at https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=
